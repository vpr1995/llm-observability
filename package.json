{
  "name": "llm-observability",
  "version": "1.0.0",
  "description": "LLM observability server with OpenTelemetry and RAG-style pipeline",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --files --respawn src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:session": "node ./scripts/test-session-correlation.js",
    "lint": "tsc --noEmit --ignoreDeprecations 6.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-prometheus": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.213.0",
    "@opentelemetry/instrumentation-express": "^0.61.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.32.0",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
